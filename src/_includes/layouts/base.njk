<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/png" href="/images/favicon.png">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title if title else "CVérifié · Vérification de CV & Diplômes en 48h" }}</title>
<meta name="description" content="{{ description if description else 'CVérifié vérifie les CV et diplômes de vos candidats en 48h. Service 100% en ligne, sans engagement, à partir de 14,90€.' }}">
<meta name="robots" content="index, follow">
<link rel="canonical" href="https://cverifie.fr{{ page.url }}">

<!-- JSON-LD: Organisation (toutes pages) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CVérifié",
  "url": "https://cverifie.fr",
  "logo": "https://cverifie.fr/images/cverifie-logo-green-sm.png",
  "description": "Service de vérification de CV et de diplômes pour recruteurs français, 100 % en ligne, sous 48 h.",
  "foundingDate": "2025",
  "address": { "@type": "PostalAddress", "addressCountry": "FR", "addressLocality": "Paris" },
  "contactPoint": { "@type": "ContactPoint", "contactType": "customer support", "url": "https://cverifie.fr/contact.html", "areaServed": "FR" },
  "sameAs": []
}
</script>
<!-- JSON-LD: WebSite (toutes pages) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CVérifié",
  "url": "https://cverifie.fr",
  "description": "Service français de vérification de CV, diplômes et expériences professionnelles pour recruteurs. 100 % en ligne, sous 48 h, à partir de 14,90 €. Conforme RGPD.",
  "inLanguage": "fr-FR",
  "publisher": {
    "@type": "Organization",
    "name": "CVérifié",
    "url": "https://cverifie.fr"
  }
}
</script>
{% if ogType == 'article' %}
<!-- JSON-LD: BlogPosting -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ articleDate }}",
  "dateModified": "{{ articleModified if articleModified else articleDate }}",
  "author": {
    "@type": "Person",
    "name": "{{ articleAuthor if articleAuthor else 'Équipe CVérifié' }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "CVérifié",
    "logo": { "@type": "ImageObject", "url": "https://cverifie.fr/images/cverifie-logo-green-sm.png" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "https://cverifie.fr{{ page.url }}" }
}
</script>
{% endif %}
{% if faqItems %}
<!-- JSON-LD: FAQPage (questions spécifiques à la page) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faqItems %}
    {
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} }
    }{{ "," if not loop.last }}
    {% endfor %}
  ]
}
</script>
{% elif hasFaq %}
<!-- JSON-LD: FAQPage (générique service) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien coûte une vérification de CV ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Une vérification CVérifié commence à 14,90 € par dossier. Le tarif varie selon les éléments contrôlés (diplômes, expériences, références). Aucun abonnement ni engagement requis." }
    },
    {
      "@type": "Question",
      "name": "En combien de temps obtenez-vous les résultats ?",
      "acceptedAnswer": { "@type": "Answer", "text": "CVérifié remet un rapport complet sous 48 heures ouvrées. Une option express 24 h est disponible sur demande." }
    },
    {
      "@type": "Question",
      "name": "Est-ce légal de vérifier le CV d'un candidat en France ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, à condition d'avoir obtenu le consentement écrit du candidat. CVérifié vous fournit les formulaires de consentement conformes au RGPD et au Code du travail." }
    },
    {
      "@type": "Question",
      "name": "Que vérifie exactement CVérifié ?",
      "acceptedAnswer": { "@type": "Answer", "text": "CVérifié contrôle les diplômes (auprès des établissements émetteurs), les expériences professionnelles (auprès des anciens employeurs), les certifications professionnelles (CACES, IT, etc.) et peut réaliser des prises de références." }
    },
    {
      "@type": "Question",
      "name": "La vérification est-elle conforme au RGPD ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui. Le consentement explicite du candidat est recueilli avant toute vérification. Les données sont traitées et hébergées en France, conformément au RGPD et à la CNIL." }
    }
  ]
}
</script>
{% endif %}

<!-- Open Graph -->
<meta property="og:type" content="{{ ogType if ogType else 'website' }}">
<meta property="og:title" content="{{ title if title else 'CVérifié · Vérification de CV & Diplômes en 48h' }}">
<meta property="og:description" content="{{ description if description else 'CVérifié vérifie les CV et diplômes de vos candidats en 48h. Service 100% en ligne, sans engagement, à partir de 14,90€.' }}">
<meta property="og:url" content="https://cverifie.fr{{ page.url }}">
<meta property="og:image" content="{{ ogImage if ogImage else 'https://cverifie.fr/images/cverifie-og.png' }}">
<meta property="og:site_name" content="CVérifié">
<meta property="og:locale" content="fr_FR">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title if title else 'CVérifié · Vérification de CV & Diplômes en 48h' }}">
<meta name="twitter:description" content="{{ description if description else 'CVérifié vérifie les CV et diplômes de vos candidats en 48h. Service 100% en ligne, sans engagement, à partir de 14,90€.' }}">
<meta name="twitter:image" content="{{ ogImage if ogImage else 'https://cverifie.fr/images/cverifie-og.png' }}">

<!-- Preconnect -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://images.unsplash.com">
<link rel="dns-prefetch" href="https://images.unsplash.com">

<!-- Preload font files (Latin) avant le CSS pour éviter le font-swap relayout -->
<link rel="preload" as="font" crossorigin href="https://fonts.gstatic.com/s/outfit/v15/QGYvz_MVcBeNP4NJtEtqUYLknw.woff2">
<link rel="preload" as="font" crossorigin href="https://fonts.gstatic.com/s/playfairdisplay/v40/nuFiD-vYSZviVYUb_rj3ij__anPXDTzYgEM86xQ.woff2">
<link rel="preload" as="font" crossorigin href="https://fonts.gstatic.com/s/playfairdisplay/v40/nuFkD-vYSZviVYUb_rj3ij__anPXDTnogkk7yRZrPA.woff2">

<!-- Fonts: display=swap, fichiers déjà preloadés ci-dessus -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"></noscript>

<!-- Preload LCP image responsive (imagesrcset pour servir la bonne source selon viewport) -->
{% if preloadImage %}<link rel="preload" as="image" href="{{ preloadImage }}"{% if preloadImageSrcset %} imagesrcset="{{ preloadImageSrcset }}" imagesizes="{{ preloadImageSizes if preloadImageSizes else '100vw' }}"{% endif %} fetchpriority="high">{% endif %}
<style>
/* ── VARIABLES ── */
:root {
  --cream: #FAF8F3;
  --cream-dark: #F0EDE5;
  --ink: #1A1A24;
  --ink-light: #44444E;
  --ink-muted: #696975;
  --green: #2D6A4F;
  --green-mid: #40916C;
  --green-light: #52B788;
  --green-pale: #D8F3DC;
  --green-ultralight: #F0FAF2;
  --border: #E0DDD5;
  --red-soft: #FFF0EE;
  --red: #C44B4B;
}

/* ── RESET ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

/* ── BASE ── */
body{
  font-family:'Outfit',sans-serif;
  background:var(--cream);
  color:var(--ink);
  line-height:1.6;
  font-size:16px;
  -webkit-font-smoothing:antialiased;
}
h1,h2,h3{font-family:'Playfair Display',serif;line-height:1.2;font-weight:600}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
button{cursor:pointer;font-family:'Outfit',sans-serif}

/* ── LOGO SIZING ── */
.logo-nav{height:38px;width:auto;display:block}
.logo-footer{height:38px;width:auto;display:block}

/* ── NAV ── */
nav.main-nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(250,248,243,0.92);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
}
.nav-inner{
  max-width:1200px;margin:0 auto;
  padding:0 2rem;height:64px;
  display:flex;align-items:center;justify-content:space-between;
}
.nav-logo{
  display:flex;align-items:center;gap:10px;
}
.nav-logo-mark{display:flex;align-items:center}
.nav-logo-text{
  font-family:'Playfair Display',serif;
  font-size:21px;font-weight:600;
  color:var(--ink);letter-spacing:-0.3px;
}
.nav-logo-text .cv{color:var(--green)}
.nav-links{display:flex;align-items:center;gap:2rem}
.nav-links a{
  font-size:14px;font-weight:500;
  color:var(--ink-light);
  transition:color .2s;
}
.nav-links a:hover{color:var(--green)}
.nav-links a.active{color:var(--green);font-weight:600}
.nav-cta{
  background:var(--green);color:white;
  padding:10px 22px;border-radius:8px;border:none;
  font-size:14px;font-weight:600;
  transition:background .2s,transform .15s;
  white-space:nowrap;
}
.nav-cta:hover{background:var(--green-mid);transform:translateY(-1px)}

/* Mobile nav additions */
.nav-mobile-right {
  display: none;
  align-items: center;
  gap: 14px;
}
.nav-cta-mobile {
  background: var(--green);
  color: white;
  padding: 11px 18px;
  border-radius: 8px;
  border: none;
  font-family: 'Outfit', sans-serif;
  font-size: 13px;
  font-weight: 600;
  white-space: nowrap;
  cursor: pointer;
  min-height: 44px;
  transition: background .2s;
  letter-spacing: 0.01em;
}
.nav-cta-mobile:active { background: var(--green-mid); }
.hamburger {
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px 2px;
  z-index: 201;
}
.hamburger span {
  display: block;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: all .35s cubic-bezier(0.4, 0, 0.2, 1);
}
.hamburger span:nth-child(1) { width: 22px; }
.hamburger span:nth-child(2) { width: 14px; margin-left: auto; }
.hamburger span:nth-child(3) { width: 22px; }
.hamburger.open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: translateX(10px); }
.hamburger.open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
.mobile-menu {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(26,26,36,0.97);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 200;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.2rem;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem;
  color: rgba(255,255,255,0.88);
  text-decoration: none;
  font-weight: 600;
  letter-spacing: -0.02em;
  transition: color .2s;
}
.mobile-menu a:hover { color: var(--green-light); }
.mobile-menu .mobile-cta {
  margin-top: 0.5rem;
  background: var(--green);
  color: white;
  padding: 15px 42px;
  border-radius: 10px;
  font-family: 'Outfit', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}
.mobile-menu .mobile-divider {
  width: 40px;
  height: 1px;
  background: rgba(255,255,255,0.12);
  margin: 0.2rem 0;
}
.mobile-menu-close {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  background: none;
  border: 1.5px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.6);
  font-size: 1.1rem;
  cursor: pointer;
  width: 38px;
  height: 38px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: border-color .2s, color .2s;
  letter-spacing: 0;
}
.mobile-menu-close:hover {
  border-color: rgba(255,255,255,0.35);
  color: white;
}
@media(max-width:768px) {
  .nav-links { display: none; }
  .nav-cta { display: none; }
  .nav-mobile-right { display: flex; }
}

/* ── FOOTER ── */
footer{
  background:var(--ink);
  padding:4rem 2rem 2rem;
  color:rgba(255,255,255,0.5);
}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-top{
  display:grid;grid-template-columns:260px 180px 1fr 1fr;
  gap:3rem;padding-bottom:3rem;
  border-bottom:1px solid rgba(255,255,255,0.08);
}
.footer-col h3{
  font-size:12px;font-weight:600;color:rgba(255,255,255,0.7);
  text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1.25rem;
}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.25rem}
.footer-col ul li a{font-size:13px;color:rgba(255,255,255,0.6);transition:color .2s;padding:6px 0;min-height:44px;display:flex;align-items:center;}
.footer-col ul li a:hover{color:var(--green-light)}
.footer-bottom{
  padding-top:2rem;
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:1rem;font-size:13px;
}
.footer-legal{display:flex;gap:.5rem;flex-wrap:wrap}
.footer-legal a{color:rgba(255,255,255,0.55);transition:color .2s;padding:8px 10px;border-radius:6px;min-height:44px;display:flex;align-items:center;}
.footer-legal a:hover{color:rgba(255,255,255,0.9)}
.footer-logo-text{
  font-family:'Playfair Display',serif;
  font-size:20px;font-weight:600;color:white;
}
.footer-social{display:flex;gap:.75rem;margin-bottom:1.5rem}
.social-icon{
  width:48px;height:48px;border-radius:10px;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.1);
  display:flex;align-items:center;justify-content:center;
  color:rgba(255,255,255,0.7);
  transition:all .2s;
}
.social-icon:hover{background:var(--green);border-color:var(--green);color:white}
.social-icon svg{width:17px;height:17px}
.footer-trust{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
.trust-logo{
  height:28px;width:auto;
  filter:brightness(0) invert(1) opacity(0.35);
  transition:opacity .2s;
}
.trust-logo:hover{opacity:.6}
.trust-badge-rgpd{
  display:flex;align-items:center;gap:5px;
  font-size:11px;font-weight:600;letter-spacing:.04em;
  color:rgba(255,255,255,0.65);
  border:1px solid rgba(255,255,255,0.12);
  padding:4px 8px;border-radius:6px;
}
.footer-stars-row{margin-bottom:.75rem}
.footer-stars{color:var(--green-light);font-size:16px;letter-spacing:2px}
.footer-rating-list{display:flex;flex-direction:column;gap:.6rem}
.rating-item{
  display:flex;align-items:center;gap:7px;
  font-size:13px;color:rgba(255,255,255,0.65);
}
.rating-item strong{color:rgba(255,255,255,0.7);font-weight:600}
.rating-item svg{flex-shrink:0}
@media(max-width:1024px){.footer-top{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.footer-top{grid-template-columns:1fr}}

/* ── DARK STORY MODE (bodyClass: dark-story) ── */
body.dark-story {
  background:#050507;
  color:rgba(255,255,255,0.82);
}
body.dark-story nav.main-nav {
  background:rgba(5,5,7,0.88);
  border-bottom-color:rgba(255,255,255,0.07);
}
/* Nav actions group (Tester + Lancer) */
.nav-actions{display:flex;align-items:center;gap:8px}
/* Demo button in nav */
.nav-demo-btn{
  font-size:.875rem;font-weight:700;
  color:var(--green);
  padding:8px 16px;border-radius:8px;
  border:1.5px solid var(--green);
  white-space:nowrap;transition:background .2s,color .2s;
}
.nav-demo-btn:hover{background:var(--green);color:white}
body.dark-story .nav-demo-btn{color:var(--green-light);border-color:var(--green-light)}
body.dark-story .nav-demo-btn:hover{background:var(--green-light);color:#050507}

/* Logo switching nav */
.logo-nav-dark { display:none; }
body.dark-story .logo-nav-default { display:none; }
body.dark-story .logo-nav-dark { display:block; }
body.dark-story .nav-links a { color:rgba(255,255,255,0.55); }
body.dark-story .nav-links a:hover { color:var(--green-light); }
body.dark-story .nav-links a.active { color:var(--green-light); }
body.dark-story .hamburger span { background:rgba(255,255,255,0.8); }
body.dark-story .nav-cta { background:var(--green); }
body.dark-story .nav-cta-mobile { background:var(--green); }

/* ── LIRE AUSSI ── */
.lire-aussi{padding:3rem 2rem;background:var(--cream-dark);border-top:1px solid var(--border)}
.lire-aussi-inner{max-width:760px;margin:0 auto}
.lire-aussi-title{font-size:1.25rem;margin-bottom:1.5rem;color:var(--ink)}
.lire-aussi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.875rem}
.lire-aussi-card{
  display:flex;flex-direction:column;gap:.5rem;
  background:white;border:1px solid var(--border);
  border-radius:12px;padding:1.25rem;
  transition:border-color .2s,box-shadow .2s;
  color:var(--ink);
  text-decoration:none;
}
.lire-aussi-card:hover{border-color:var(--green);box-shadow:0 4px 16px rgba(45,106,79,.1);text-decoration:none}
.lire-aussi-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--green)}
.lire-aussi-name{font-size:.875rem;font-weight:600;line-height:1.4;color:var(--ink)}
.lire-aussi-arrow{font-size:.875rem;color:var(--green);margin-top:.25rem}
</style>
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
{% include "nav.njk" %}
{{ content | safe }}
{% if ogType == 'article' %}
{% set slug = page.fileSlug %}
{% set related = relatedArticles[slug] %}
{% if related and related.length %}
<section class="lire-aussi">
  <div class="lire-aussi-inner">
    <h2 class="lire-aussi-title">Lire aussi</h2>
    <div class="lire-aussi-grid">
      {% for item in related %}
      <a href="/blog/{{ item.slug }}.html" class="lire-aussi-card">
        <span class="lire-aussi-label">Article</span>
        <span class="lire-aussi-name">{{ item.title }}</span>
        <span class="lire-aussi-arrow">→</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
{% endif %}
{% include "footer.njk" %}
</body>
</html>
