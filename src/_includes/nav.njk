<style>
/* Mobile nav additions */
.nav-mobile-right {
  display: none;
  align-items: center;
  gap: 14px;
}
.nav-cta-mobile {
  background: var(--green);
  color: white;
  padding: 9px 18px;
  border-radius: 8px;
  border: none;
  font-family: 'Outfit', sans-serif;
  font-size: 13px;
  font-weight: 600;
  white-space: nowrap;
  cursor: pointer;
  transition: background .2s;
  letter-spacing: 0.01em;
}
.nav-cta-mobile:active { background: var(--green-mid); }
.hamburger {
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px 2px;
  z-index: 201;
}
.hamburger span {
  display: block;
  height: 1.5px;
  background: var(--ink);
  border-radius: 2px;
  transition: all .35s cubic-bezier(0.4, 0, 0.2, 1);
}
.hamburger span:nth-child(1) { width: 22px; }
.hamburger span:nth-child(2) { width: 14px; margin-left: auto; }
.hamburger span:nth-child(3) { width: 22px; }
.hamburger.open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: translateX(10px); }
.hamburger.open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
.mobile-menu {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(26,26,36,0.97);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 200;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.2rem;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem;
  color: rgba(255,255,255,0.88);
  text-decoration: none;
  font-weight: 600;
  letter-spacing: -0.02em;
  transition: color .2s;
}
.mobile-menu a:hover { color: var(--green-light); }
.mobile-menu .mobile-cta {
  margin-top: 0.5rem;
  background: var(--green);
  color: white;
  padding: 15px 42px;
  border-radius: 10px;
  font-family: 'Outfit', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}
.mobile-menu .mobile-divider {
  width: 40px;
  height: 1px;
  background: rgba(255,255,255,0.12);
  margin: 0.2rem 0;
}
.mobile-menu-close {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  background: none;
  border: 1.5px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.6);
  font-size: 1.1rem;
  cursor: pointer;
  width: 38px;
  height: 38px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: border-color .2s, color .2s;
  letter-spacing: 0;
}
.mobile-menu-close:hover {
  border-color: rgba(255,255,255,0.35);
  color: white;
}
@media(max-width:768px) {
  .nav-links { display: none; }
  .nav-cta { display: none; }
  .nav-mobile-right { display: flex; }
}
</style>

<nav>
  <div class="nav-inner">
    <div class="nav-logo">
      <a href="/"><img src="/images/cverifie-logo-green.png" alt="CVérifié" class="logo-nav"></a>
    </div>
    <div class="nav-links">
      <a href="/#comment">Comment ça marche</a>
      <a href="/#tarifs">Tarifs</a>
      <a href="/#candidats">Pour les candidats</a>
      <a href="/#faq">FAQ</a>
      <a href="/blog/" class="{{ 'active' if '/blog' in page.url else '' }}">Blog</a>
    </div>
    <button class="nav-cta" onclick="window.location='/commander.html'">Lancer une vérification</button>
    <div class="nav-mobile-right">
      <button class="nav-cta-mobile" onclick="window.location='/commander.html'">Lancer une vérification</button>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div class="mobile-menu" id="mobileMenu">
  <button class="mobile-menu-close" id="mobileClose">&#x2715;</button>
  <a href="/" onclick="closeMobileMenu()">Accueil</a>
  <a href="/#comment" onclick="closeMobileMenu()">Comment ça marche</a>
  <a href="/#tarifs" onclick="closeMobileMenu()">Tarifs</a>
  <a href="/#candidats" onclick="closeMobileMenu()">Pour les candidats</a>
  <a href="/#faq" onclick="closeMobileMenu()">FAQ</a>
  <a href="/blog/" onclick="closeMobileMenu()">Blog</a>
  <div class="mobile-divider"></div>
  <a href="/commander.html" class="mobile-cta">Lancer une vérification</a>
</div>

<script>
var hamburger = document.getElementById('hamburger');
var mobileMenu = document.getElementById('mobileMenu');
var mobileClose = document.getElementById('mobileClose');
function openMobileMenu(){ hamburger.classList.add('open'); mobileMenu.classList.add('open'); document.body.style.overflow='hidden'; }
function closeMobileMenu(){ hamburger.classList.remove('open'); mobileMenu.classList.remove('open'); document.body.style.overflow=''; }
hamburger.addEventListener('click', function(){ mobileMenu.classList.contains('open') ? closeMobileMenu() : openMobileMenu(); });
mobileClose.addEventListener('click', closeMobileMenu);
</script>
